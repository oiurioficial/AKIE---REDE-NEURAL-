# AKIE Worker — variáveis de ambiente
# Copie para .env e preencha os valores reais

# ── Firebase (obrigatório) ────────────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# ── Web Search (pelo menos uma recomendada — ativa Modo EXPANSION) ────────
# Serper — Google Search (https://serper.dev)
SERPER_API_KEY=sua_chave_serper_aqui

# Tavily — complemento ou fallback do Serper
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxx

# ── Persistência do modelo ────────────────────────────────────────────────
# No Railway: montar volume em /data e usar esse path
MODEL_DIR=/data/akie_model
